# Groq API Configuration (REPLACE WITH YOUR REAL API KEY)
GROQ_API_KEY=your_groq_api_key_here

# Email Configuration (REPLACE WITH YOUR REAL EMAIL CREDENTIALS)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Instructions:
# 1. Get your Groq API key from https://console.groq.com/keys
# 2. For Gmail: Enable 2FA and create an App Password at https://myaccount.google.com/apppasswords
# 3. Replace the placeholder values above with your actual credentials